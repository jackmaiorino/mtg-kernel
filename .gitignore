# Rust build output
/target/
**/*.rs.bk

# Python bytecode, packaging, and virtual environments
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
/build/
/dist/
/.venv/
/venv/
/env/

# Python test, lint, type-check, and coverage caches
/.coverage
/.coverage.*
/coverage.xml
/htmlcov/
/.hypothesis/
/.mypy_cache/
/.nox/
/.pytest_cache/
/.ruff_cache/
/.tox/

# Local experiment and model output
/artifacts/
/checkpoints/
/corpora/
/local-training/
/models/
/outputs/
/runs/
*.log
*.pt
*.pth
*.tmp

# Local configuration and editor state
/.env
/.env.*
!/.env.example
/.idea/
/.vscode/
*.swp
*.swo
*~

# Operating-system metadata
.DS_Store
Desktop.ini
Thumbs.db
